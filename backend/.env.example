# Copy to .env and fill real values
SECRET_KEY=change-me-to-a-random-secret
# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=DB_PASSWORD
DB_NAME=cv_python_tigerpro
# HuggingFace 访问令牌（拉取受限/私有模型权重时用，需先在模型页获批访问权）
# 获取：https://huggingface.co/settings/tokens
HF_TOKEN=
# ModelScope（模搭社区）访问令牌（拉取受限模型权重时用）
# 获取：https://modelscope.cn/my/myaccesstoken
MODELSCOPE_TOKEN=
# Roboflow API Key（拉取 Universe 模型权重，如 NASASpaceflight Rocket Detect）
# 获取：https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=
# 火箭回收跟踪：一级箭体参考高度（米），用于视频检测中像素速度换算为米/秒
ROCKET_STAGE_HEIGHT_M=47
# DeepSeek（检测结果 AI 分析报告）API Key
# 获取：https://platform.deepseek.com/api_keys
# 留空时 AI 报告自动降级为案例库兜底（功能仍可用）
DEEPSEEK_API_KEY=
