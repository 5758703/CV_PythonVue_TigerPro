# Copy to .env and fill real values
SECRET_KEY=change-me-to-a-random-secret
# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=DB_PASSWORD
DB_NAME=cv_python_tigerpro
# HuggingFace 访问令牌（拉取受限/私有模型权重时用，需先在模型页获批访问权）
# 获取：https://huggingface.co/settings/tokens
HF_TOKEN=
# ModelScope（模搭社区）访问令牌（拉取受限模型权重时用）
# 获取：https://modelscope.cn/my/myaccesstoken
MODELSCOPE_TOKEN=
# Roboflow API Key（拉取 Universe 模型权重 / 标注工具推送）
# 获取：https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=
# Roboflow Public API Key（可选，前端/公开场景）
ROBOFLOW_PUBLIC_API_KEY=
# Roboflow 工作区 slug（标注工具推送时可选，留空则用默认 workspace）
ROBOFLOW_WORKSPACE=
# CVAT（模型训练-数据标注-CVAT 工具）：云端一般为 https://app.cvat.ai
CVAT_URL=
# Personal Access Token（推荐）：形如 xxxx.yyyy，平台会使用 Bearer 鉴权
CVAT_TOKEN=
# 可选强制鉴权：bearer | token（默认：token 含 "." 用 Bearer，否则用 Token）
# CVAT_AUTH_SCHEME=
# 若无 Token，可用用户名密码
CVAT_USERNAME=
CVAT_PASSWORD=
# 可选：本机 X-AnyLabeling 可执行命令（仅提示用，导出/导入不依赖）
XANYLABELING_CMD=
# Ultralytics YOLO CPU 热路径推理后端（跟踪/车辆/告警视频）
# auto=优先 OpenVINO（失败回退 .pt）；torch=强制 PyTorch；openvino=强制 OV
YOLO_INFER_BACKEND=auto
# OpenVINO 精度：fp16（默认）| int8（需校准，可能掉点）
YOLO_OPENVINO_PRECISION=fp16
YOLO_OPENVINO_IMGSZ=640
# 火箭回收跟踪：一级箭体参考高度（米），用于视频检测中像素速度换算为米/秒
ROCKET_STAGE_HEIGHT_M=47
# DeepSeek（检测结果 AI 分析报告）API Key
# 获取：https://platform.deepseek.com/api_keys
# 留空时 AI 报告自动降级为案例库兜底（功能仍可用）
DEEPSEEK_API_KEY=
